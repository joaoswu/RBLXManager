<Application x:Class="RblxManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        
        <!-- ================= EMERALD-TO-CYAN BRAND GRADIENT ================= -->
        <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#10B981" Offset="0.0"/> <!-- Emerald Green -->
            <GradientStop Color="#06B6D4" Offset="1.0"/> <!-- Cyan/Teal -->
        </LinearGradientBrush>

        <!-- ================= STAGGERED DOT GRID BRUSH ================= -->
        <DrawingBrush x:Key="StaggeredDotGridBrush" TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="#08FFFFFF"> <!-- Softer 4% opacity dots for improved contrast -->
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="0,0" RadiusX="1.2" RadiusY="1.2" />
                            <EllipseGeometry Center="20,20" RadiusX="1.2" RadiusY="1.2" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

