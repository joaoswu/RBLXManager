<Window x:Class="RblxManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roblox Account Manager" 
        Height="720" Width="1020"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        FontFamily="Montserrat, Inter, Segoe UI Variable Display, Segoe UI, Century Gothic, Arial, sans-serif"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    
    <!-- Native Windows 11 drop shadow and resizing hooks without transparency lag -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="50" 
                      ResizeBorderThickness="6" 
                      GlassFrameThickness="0" 
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ================= PRIMARY ACTION BUTTON STYLE WITH HOVER SCALE ================= -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BrandGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#10B981" Opacity="0.15" ShadowDepth="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                             To="1.03" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                             To="1.03" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border" 
                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" 
                                                             To="0.4" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                             To="1.0" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                             To="1.0" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border" 
                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" 
                                                             To="0.15" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================= SECONDARY BUTTON STYLE WITH HOVER SCALE ================= -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1C1C1E"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="#2A2A2E"
                                BorderThickness="1"
                                CornerRadius="8" 
                                SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252528"/>
                                <Setter Property="BorderBrush" Value="#3A3A3E"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                             To="1.03" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                             To="1.03" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                             To="1.0" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                             To="1.0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ================= INLINE VECTOR ACTION BUTTON STYLES ================= -->
        <Style x:Key="InlinePlayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2210B981"/> 
            <Setter Property="Foreground" Value="#10B981"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="13" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <!-- Sharp Vector Arrow -->
                            <Path Data="{StaticResource PlayGeometry}" 
                                  Fill="{TemplateBinding Foreground}" 
                                  Width="9" Height="9" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"
                                  Margin="1,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#10B981"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineDeleteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="13" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <!-- Sharp Vector Trash Can -->
                            <Path Data="{StaticResource TrashGeometry}" 
                                  Fill="{TemplateBinding Foreground}" 
                                  Width="10" Height="10" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33EF4444"/> 
                                <Setter Property="Foreground" Value="#EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================= MODERN SLIDER STYLE ================= -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid x:Name="GridRoot" Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            </Grid.RowDefinitions>
                            
                            <Border x:Name="TrackBackground" 
                                    Grid.Row="0" 
                                    Height="4" 
                                    Margin="5,0"
                                    Background="#2A2A2E" 
                                    CornerRadius="2" 
                                    VerticalAlignment="Center"/>

                            <Track x:Name="PART_Track" Grid.Row="0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#10B981" CornerRadius="2" Margin="5,0,-5,0"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="ThumbEllipse" 
                                                         Fill="White" 
                                                         Stroke="#10B981" 
                                                         StrokeThickness="3" 
                                                         Width="14" 
                                                         Height="14">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.3" ShadowDepth="1"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbEllipse" Property="Fill" Value="#10B981"/>
                                                        <Setter TargetName="ThumbEllipse" Property="Stroke" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#9A0F0F12" BorderBrush="#1C1C1E" BorderThickness="1" CornerRadius="12" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>   <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content Area (3 Columns) -->
            </Grid.RowDefinitions>

            <!-- ================= HEADER / TITLEBAR ================= -->
            <Border Grid.Row="0" Background="#150F0F10" CornerRadius="12,12,0,0" ClipToBounds="True" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2"/>   <!-- Brand Line Accent -->
                    <RowDefinition Height="*"/>   <!-- Title Bar Contents -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Title/Logo -->
                    <ColumnDefinition Width="*"/>    <!-- Spacing -->
                    <ColumnDefinition Width="Auto"/> <!-- Window Actions -->
                </Grid.ColumnDefinitions>

                <!-- Emerald-to-Cyan Brand line at the very top -->
                <Border Grid.Row="0" Grid.ColumnSpan="3" Background="{DynamicResource BrandGradient}" Height="2" CornerRadius="11,11,0,0"/>

                <!-- Brand Section -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <!-- Vector Sync Logo icon -->
                    <Path Data="M 12,2 A 10,10 0 1,0 22,12 A 10,10 0 0,0 12,2 Z" 
                          Fill="{DynamicResource BrandGradient}" 
                          Width="14" Height="14" 
                          Stretch="Uniform" 
                          VerticalAlignment="Center" 
                          Margin="0,0,10,0"/>
                    <TextBlock Text="RblxManager" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window Control Buttons (Chrome integration friendly) -->
                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0" WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- Vector Mini-Mode Toggle -->
                    <Button Style="{StaticResource CircleButtonStyle}" Click="MiniModeButton_Click" ToolTip="Toggle Mini-Mode" Margin="0,0,8,0">
                        <Path Data="M4,4H20V20H4V4M6,6V18H10V6H6M12,6V18H18V6H12Z" Fill="#B2FFFFFF" Width="13" Height="13" Stretch="Uniform"/>
                    </Button>
                    <!-- Vector Settings Gear -->
                    <Button Style="{StaticResource CircleButtonStyle}" Click="SettingsButton_Click" Margin="0,0,8,0">
                        <Path Data="{StaticResource SettingsGeometry}" Fill="#B2FFFFFF" Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                    <!-- Vector Close Cross -->
                    <Button Style="{StaticResource CircleButtonStyle}" Click="CloseButton_Click">
                        <Path Data="{StaticResource CloseGeometry}" Fill="#B2FFFFFF" Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

            <!-- ================= 3-PANEL DASHBOARD LAYOUT ================= -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ColAccounts" Width="290"/> <!-- Column 0: Left Panel (Accounts List) -->
                    <ColumnDefinition x:Name="ColSplitter1" Width="1"/>   <!-- Column 1: Splitter -->
                    <ColumnDefinition x:Name="ColSettings" Width="410"/> <!-- Column 2: Middle Panel (Login & Settings) -->
                    <ColumnDefinition x:Name="ColSplitter2" Width="1"/>   <!-- Column 3: Splitter -->
                    <ColumnDefinition x:Name="ColMonitor" Width="*"/>   <!-- Column 4: Right Panel (Instance Monitor) -->
                </Grid.ColumnDefinitions>

                <!-- ================= LEFT PANEL: ACCOUNTS SELECTOR ================= -->
                <Grid Grid.Column="0" Margin="14,14,10,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Search Box -->
                        <RowDefinition Height="*"/>    <!-- Accounts Scroll Area -->
                    </Grid.RowDefinitions>

                    <!-- Search & Tag Filter Grid -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <TextBox x:Name="SearchBox" 
                                     Style="{StaticResource GlowingTextBoxStyle}" 
                                     Height="36" 
                                     Padding="34,8,12,8"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#1C1C1E"
                                     Background="#111112"
                                     ToolTip="Search by username, ID, or use prefixes: status:running, tag:Main, fav:true, robux&gt;500"
                                     TextChanged="SearchBox_TextChanged"/>

                            <Path Data="{StaticResource SearchGeometry}" 
                                  Fill="#616163" 
                                  Width="13" Height="13" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Left" 
                                  Margin="12,0,0,0" 
                                  VerticalAlignment="Center" 
                                  IsHitTestVisible="False"/>

                            <TextBlock Text="Search..." 
                                       IsHitTestVisible="False" 
                                       Foreground="#616163" 
                                       FontSize="12.5" 
                                       VerticalAlignment="Center" 
                                       Margin="34,0,12,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <ComboBox x:Name="TagFilterComboBox" 
                                  Grid.Column="2" 
                                  Height="36" 
                                  Background="#111112" 
                                  Foreground="#E5E7EB" 
                                  BorderBrush="#1C1C1E" 
                                  Padding="8,0,0,0"
                                  VerticalContentAlignment="Center"
                                  SelectionChanged="TagFilterComboBox_SelectionChanged">
                            <ComboBoxItem Content="All" IsSelected="True"/>
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Main"/>
                            <ComboBoxItem Content="Alt"/>
                            <ComboBoxItem Content="Bot"/>
                            <ComboBoxItem Content="Dev"/>
                        </ComboBox>
                    </Grid>

                    <!-- Scrollable Accounts ListBox -->
                    <ListBox x:Name="AccountsListBox" 
                             Grid.Row="1"
                             Style="{StaticResource ModernListBoxStyle}"
                             ItemContainerStyle="{StaticResource ModernListBoxItemStyle}"
                             SelectionChanged="AccountsListBox_SelectionChanged"
                             MouseDoubleClick="AccountsListBox_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2,8,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <!-- Avatar -->
                                        <ColumnDefinition Width="*"/>    <!-- User Info -->
                                        <ColumnDefinition Width="Auto"/> <!-- Action Buttons -->
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" 
                                            Width="32" Height="32" 
                                            CornerRadius="16" 
                                            ClipToBounds="True" 
                                            Background="#18181A" 
                                            BorderBrush="{DynamicResource BrandGradient}"
                                            BorderThickness="1.5"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center">
                                        <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- Username and ID + Dynamic Tag & Resource Stats -->
                                    <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,6,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Row 0, Column 0: Username -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                                   Text="{Binding Username}" 
                                                   Foreground="White" 
                                                   FontSize="12.5" 
                                                   FontWeight="Bold" 
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>

                                        <!-- Row 0, Column 1: Tag Badge -->
                                        <Border x:Name="TagBadge" 
                                                Grid.Row="0" Grid.Column="1" 
                                                Margin="6,0,0,0" Padding="5,1.5" 
                                                CornerRadius="4" BorderThickness="1" 
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tag}" Value="None">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Tag}" Value="Main">
                                                            <Setter Property="Background" Value="#3310B981"/>
                                                            <Setter Property="BorderBrush" Value="#10B981"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Tag}" Value="Alt">
                                                            <Setter Property="Background" Value="#33F59E0B"/>
                                                            <Setter Property="BorderBrush" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Tag}" Value="Bot">
                                                            <Setter Property="Background" Value="#338B5CF6"/>
                                                            <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Tag}" Value="Dev">
                                                            <Setter Property="Background" Value="#333B82F6"/>
                                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Tag}" FontSize="8.5" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Row 1: ID and RAM stats -->
                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,2,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding UserId, StringFormat='ID: {0}'}" 
                                                       Foreground="#9CA3AF" FontSize="10" 
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="80"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Margin="6,0,0,0" VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Ellipse Width="6" Height="6" Fill="#10B981" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding StatusText}" Foreground="#10B981" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Inline Actions -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource FavoriteButtonStyle}" Margin="0,0,6,0"
                                                ToolTip="Toggle favorite"
                                                CommandParameter="{Binding}"
                                                Click="ToggleFavoriteRow_Click">
                                            <TextBlock FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#9734;"/>
                                                        <Setter Property="Foreground" Value="#6B7280"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                <Setter Property="Text" Value="&#9733;"/>
                                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                        <Button Style="{StaticResource InlinePlayButtonStyle}"
                                                Margin="0,0,6,0"
                                                CommandParameter="{Binding}"
                                                Click="LaunchAccountRow_Click"/>
                                        <Button Style="{StaticResource InlineDeleteButtonStyle}"
                                                CommandParameter="{Binding}"
                                                Click="DeleteAccountRow_Click"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty state placeholder when ListBox has no accounts -->
                    <StackPanel x:Name="EmptyStatePanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Vector Silhouette -->
                        <Path Data="{StaticResource UserGeometry}" Fill="#1C1C1E" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center"/>
                        <TextBlock Text="No accounts found" Foreground="#616163" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Splitter Border Line (Left to Middle) -->
                <Border Grid.Column="1" Background="#1C1C1E" Width="1" VerticalAlignment="Stretch"/>

                <!-- ================= MIDDLE PANEL: CONTROLS & ACTIONS ================= -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,14,14,14">
                        
                        <!-- CARD 1: ACCOUNT ACQUISITION (Frosted Acrylic) -->
                        <Border Style="{StaticResource GlassCardStyle}" Padding="16,14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Register Account" Foreground="White" FontSize="13.5" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="Choose web browser login (recommended) or paste your cookie directly." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,0,0,12"/>

                                <!-- Primary Website Login Action with Gradient -->
                                <Button Style="{StaticResource PrimaryButtonStyle}" 
                                        Height="40" 
                                        Margin="0,0,0,14"
                                        Click="WebLoginButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Vector globe icon -->
                                        <Path Data="{StaticResource GlobeGeometry}" 
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                              Width="14" Height="14" 
                                              Stretch="Uniform" 
                                              Margin="0,0,8,0" 
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="LOGIN VIA WEBSITE" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="Or Paste Cookie" Foreground="#9CA3AF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <Border Background="Transparent" BorderBrush="#10B981" BorderThickness="1" CornerRadius="4" Padding="5,2" HorizontalAlignment="Right">
                                        <TextBlock Text="ROBLOSECURITY" Foreground="#10B981" FontSize="9.5" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="CookieInputBox" 
                                             Style="{StaticResource GlowingTextBoxStyle}" 
                                             Grid.Column="0"
                                             Height="38" 
                                             FontFamily="Consolas"
                                             VerticalContentAlignment="Center"
                                             GotFocus="CookieInputBox_GotFocus"
                                             LostFocus="CookieInputBox_LostFocus"/>

                                    <Button Grid.Column="1" 
                                            Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="IMPORT" 
                                            Width="76" Height="38" 
                                            Margin="8,0,0,0"
                                            Click="ImportButton_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- CARD 2: CONFIGURATION & SETTINGS (Frosted Acrylic) -->
                        <Border Style="{StaticResource GlassCardStyle}" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Settings &amp; Launch Options" Foreground="White" FontSize="13.5" FontWeight="Bold" Margin="0,0,0,12"/>

                                <!-- Place ID Input Row -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Target Place ID" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Game ID to automatically join on launch." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11.5" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="PlaceIdInputBox" 
                                             Style="{StaticResource GlowingTextBoxStyle}" 
                                             Grid.Column="1"
                                             Height="36" 
                                             Text="" 
                                             HorizontalContentAlignment="Center" 
                                             VerticalContentAlignment="Center"
                                             FontFamily="Consolas"
                                             TextChanged="PlaceIdInputBox_TextChanged"/>
                                </Grid>

                                <!-- Private Server Link/Code Input Row -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Private Server Link" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Paste VIP link or link code." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11.5" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="PrivateServerCodeInput" 
                                             Style="{StaticResource GlowingTextBoxStyle}" 
                                             Grid.Column="1"
                                             Height="36" 
                                             Text="" 
                                             VerticalContentAlignment="Center"
                                             FontSize="11.5"
                                             TextChanged="PrivateServerCodeInput_TextChanged"/>
                                </Grid>

                                <!-- Job ID Input Row -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Server Job ID" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="GUID of Roblox server instance." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11.5" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="JobIdInput" 
                                             Style="{StaticResource GlowingTextBoxStyle}" 
                                             Grid.Column="1"
                                             Height="36" 
                                             Text="" 
                                             VerticalContentAlignment="Center"
                                             FontSize="11.5"
                                             FontFamily="Consolas"
                                             TextChanged="JobIdInput_TextChanged"/>
                                </Grid>

                                <Border Height="1" Background="#1C1C1E" Margin="0,0,0,12"/>

                                <!-- Quick Join Row -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                                        <TextBlock Text="Quick Join" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Paste a game link/ID or a profile link/@username, then launch the selected account." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11.5" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="QuickJoinBox"
                                             Style="{StaticResource GlowingTextBoxStyle}"
                                             Grid.Row="2" Grid.Column="0"
                                             Height="34"
                                             VerticalContentAlignment="Center"
                                             FontSize="11.5"/>
                                    <Button Grid.Row="2" Grid.Column="2"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="JOIN"
                                            Height="34"
                                            FontSize="10.5"
                                            FontWeight="Bold"
                                            Click="QuickJoinButton_Click"/>
                                </Grid>

                                <Border Height="1" Background="#1C1C1E" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Row 1: Multi-Client -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Enable Multi-Client" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Allows running multiple independent game clients simultaneously." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="MultiClientToggle" 
                                              Grid.Row="0" Grid.Column="1" 
                                              Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center"
                                              Checked="MultiClientToggle_Changed"
                                              Unchecked="MultiClientToggle_Changed"/>

                                    <!-- Row 2: Auto-Launch -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Auto-Launch Roblox" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Launch Roblox immediately upon importing an account." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="AutoLaunchToggle" 
                                              Grid.Row="2" Grid.Column="1" 
                                              Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Roblox Log & Cache Cleaner Section -->
                                <Border Height="1" Background="#1C1C1E" Margin="0,12,0,12"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="🧹 CLEAN LOGS &amp; CACHE" 
                                        Height="36" 
                                        Click="CleanLogs_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- CARD 3: GROUP LAUNCHER (Frosted Acrylic) -->
                        <Border Style="{StaticResource GlassCardStyle}" Padding="16,14" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Group Launcher" Foreground="White" FontSize="13.5" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="Launch multiple accounts into the same game server concurrently." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="GroupSelector" 
                                              Height="36" 
                                              Background="#111112" 
                                              Foreground="#E5E7EB" 
                                              BorderBrush="#1C1C1E" 
                                              Padding="8,0,0,0"
                                              VerticalContentAlignment="Center"
                                              SelectionChanged="GroupSelector_SelectionChanged"/>
                                    <Button Grid.Column="1" 
                                            Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="MANAGE" 
                                            Width="80" Height="36" 
                                            Margin="8,0,0,0"
                                            Click="ManageGroupsButton_Click"/>
                                </Grid>

                                <Button x:Name="LaunchGroupButton" 
                                        Style="{StaticResource PrimaryButtonStyle}" 
                                        Height="40" 
                                        Content="🚀 LAUNCH GROUP" 
                                        Click="LaunchGroupButton_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Splitter Border Line (Middle to Right) -->
                <Border Grid.Column="3" Background="#1C1C1E" Width="1" VerticalAlignment="Stretch"/>

                <!-- ================= RIGHT PANEL: INSTANCE MONITOR & INSPECTOR ================= -->
                <Grid Grid.Column="4" Margin="10,14,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="200"/> <!-- Active Instances Card -->
                        <RowDefinition Height="12"/>  <!-- Spacer -->
                        <RowDefinition Height="*"/>   <!-- Account Inspector Card -->
                    </Grid.RowDefinitions>

                    <!-- CARD 1: RUNNING INSTANCES (Frosted Acrylic) -->
                    <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}" Padding="14,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Title / Action Header Grid -->
                                <RowDefinition Height="*"/>    <!-- Scroll List -->
                            </Grid.RowDefinitions>

                            <!-- Header with title and Kill All Action -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="Running Clients" Foreground="White" FontSize="13.5" FontWeight="Bold"/>
                                    <TextBlock x:Name="RunningClientsSummaryText" Text="0 client(s) active | 0 MB RAM" Foreground="#9CA3AF" FontSize="10.5" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="KILL ALL" 
                                        Width="68" Height="24" 
                                        FontSize="9.5" 
                                        FontWeight="Bold"
                                        Foreground="#EF4444" 
                                        BorderBrush="#66EF4444"
                                        Click="KillAllClients_Click"
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Scroll List of processes -->
                            <ListBox x:Name="InstancesListBox" 
                                     Grid.Row="1"
                                     Style="{StaticResource ModernListBoxStyle}"
                                     ItemContainerStyle="{StaticResource ModernListBoxItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Margin added, Width removed to support stretch layout without slicing close buttons -->
                                        <Grid Margin="4,2,8,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <!-- Status Circle -->
                                                <ColumnDefinition Width="*"/>    <!-- Process Details -->
                                                <ColumnDefinition Width="Auto"/> <!-- Terminate Button -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Status Dot -->
                                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#10B981" Margin="2,0,10,0" VerticalAlignment="Center"/>

                                            <!-- Details -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Pid, StringFormat='Process PID: {0}'}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Memory, StringFormat='RAM Usage: {0}'}" Foreground="#9CA3AF" FontSize="10.5" Margin="0,1,0,0"/>
                                            </StackPanel>

                                            <!-- Terminate Action -->
                                            <Button Grid.Column="2" 
                                                    Style="{StaticResource InlineDeleteButtonStyle}" 
                                                    CommandParameter="{Binding}"
                                                    Click="KillProcess_Click"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Inactive state placeholder -->
                            <StackPanel x:Name="NoInstancesPanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <!-- Vector Screen Monitor -->
                                <Path Data="{StaticResource ScreenGeometry}" Fill="#1C1C1E" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center"/>
                                <TextBlock Text="No active game clients" Foreground="#616163" FontSize="11.5" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CARD 2: ACCOUNT INSPECTOR (Gold Roblox hex badge) -->
                    <Border Grid.Row="2" Style="{StaticResource GlassCardStyle}" Padding="16,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Header -->
                                <RowDefinition Height="*"/>    <!-- Details / Placeholder -->
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <StackPanel HorizontalAlignment="Left">
                                    <TextBlock Text="Account Inspector" Foreground="White" FontSize="13.5" FontWeight="Bold"/>
                                    <TextBlock Text="Real-time Roblox API session stats." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button x:Name="RefreshStatsButton" 
                                        Style="{StaticResource CircleButtonStyle}" 
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Top" 
                                        Visibility="Collapsed"
                                        Click="RefreshStatsButton_Click">
                                    <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4c-4.42,0-7.99,3.58-7.99,8s3.57,8 7.99,8c3.73,0,6.84,-2.55,7.73,-6h-2.08c-0.82,2.33-3.07,4-5.65,4-3.31,0-6,-2.69-6,-6s2.69,-6 6,-6c1.66,0,3.14,0.69 4.22,1.78L13,11h7V4l-2.35,2.35z" Fill="#B2FFFFFF" Width="12" Height="12" Stretch="Uniform"/>
                                </Button>
                            </Grid>

                            <!-- 1. EMPTY STATE PLACEHOLDER / HOME DASHBOARD -->
                            <Grid x:Name="InspectorPlaceholder" Grid.Row="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="2,4,2,2">
                                        <!-- Welcome/Header -->
                                        <TextBlock Text="Welcome to RblxManager" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBlock Text="System overview and quick controls." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,0,0,16"/>

                                        <!-- Stats Cards (2 Columns, 2 Rows) -->
                                        <UniformGrid Columns="2" Rows="2" Margin="0,0,0,16">
                                            <!-- Stat 1: Total Accounts -->
                                            <Border Background="#0CFFFFFF" CornerRadius="8" Padding="10,12" Margin="0,0,6,6" BorderBrush="#10FFFFFF" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="TOTAL ACCOUNTS" Foreground="#9CA3AF" FontSize="9.5" FontWeight="Bold"/>
                                                    <TextBlock x:Name="DashTotalAccountsText" Text="0" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- Stat 2: Active Clients -->
                                            <Border Background="#0CFFFFFF" CornerRadius="8" Padding="10,12" Margin="6,0,0,6" BorderBrush="#10FFFFFF" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="ACTIVE CLIENTS" Foreground="#9CA3AF" FontSize="9.5" FontWeight="Bold"/>
                                                    <TextBlock x:Name="DashActiveClientsText" Text="0" Foreground="#10B981" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Stat 3: Total RAM -->
                                            <Border Background="#0CFFFFFF" CornerRadius="8" Padding="10,12" Margin="0,6,6,0" BorderBrush="#10FFFFFF" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="TOTAL MEMORY" Foreground="#9CA3AF" FontSize="9.5" FontWeight="Bold"/>
                                                    <TextBlock x:Name="DashTotalRamText" Text="0 MB" Foreground="#3B82F6" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Stat 4: Cached Robux -->
                                            <Border Background="#0CFFFFFF" CornerRadius="8" Padding="10,12" Margin="6,6,0,0" BorderBrush="#10FFFFFF" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="CACHED ROBUX" Foreground="#9CA3AF" FontSize="9.5" FontWeight="Bold"/>
                                                    <TextBlock x:Name="DashTotalRobuxText" Text="0 R$" Foreground="#F59E0B" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <!-- Quick Action Buttons -->
                                        <TextBlock Text="Quick Actions" Foreground="White" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Button Grid.Row="0" Grid.Column="0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="🚀 LAUNCH FAVS"
                                                    Height="30" FontSize="9.5" FontWeight="Bold"
                                                    Click="LaunchFavorites_Click"/>

                                            <Button Grid.Row="0" Grid.Column="2"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="🛡️ VERIFY COOKIES"
                                                    Height="30" FontSize="9.5" FontWeight="Bold"
                                                    Click="VerifyAllCookies_Click"/>

                                            <Button Grid.Row="2" Grid.Column="0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="📂 ROBLOX FOLDER"
                                                    Height="30" FontSize="9.5" FontWeight="Bold"
                                                    Click="ExploreRobloxFolder_Click"/>

                                            <Button Grid.Row="2" Grid.Column="2"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="🧹 CLEAN LOGS"
                                                    Height="30" FontSize="9.5" FontWeight="Bold"
                                                    Click="CleanLogsNowButton_Click"/>

                                            <Button Grid.Row="4" Grid.Column="0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="🛑 KILL CLIENTS"
                                                    Height="30" FontSize="9.5" FontWeight="Bold"
                                                    Click="KillAllClients_Click"/>

                                            <Button Grid.Row="4" Grid.Column="2"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="💾 BACKUP FILES"
                                                    Height="30" FontSize="9.5" FontWeight="Bold"
                                                    Click="BackupProfiles_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>

                            <!-- 2. DETAILS LAYOUT -->
                            <Grid x:Name="InspectorGrid" Grid.Row="1" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Robux Pill -->
                                    <RowDefinition Height="12"/>  <!-- Spacer -->
                                    <RowDefinition Height="*"/>    <!-- Grid Data -->
                                </Grid.RowDefinitions>

                                <!-- Gold Roblox Diamond Hexagon Badge -->
                                <Border Grid.Row="0" CornerRadius="10" Background="#1A1105" BorderBrush="#33F59E0B" BorderThickness="1" Padding="14,10" SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" Color="#F59E0B" Opacity="0.12" ShadowDepth="0"/>
                                    </Border.Effect>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Official Roblox Hexagon Icon Path -->
                                            <Path Data="{StaticResource RobuxHexGeometry}" 
                                                  Fill="#F59E0B" 
                                                  Width="14" Height="14" 
                                                  Stretch="Uniform" 
                                                  Margin="0,0,8,0" 
                                                  VerticalAlignment="Center"/>
                                            <TextBlock x:Name="InspectorRobuxText" Text="Loading..." Foreground="#F59E0B" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border Background="#22F59E0B" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="ROBUX" Foreground="#F59E0B" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Detail List Rows -->
                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- Display Name -->
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/> <!-- Created -->
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/> <!-- Session -->
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/> <!-- Tag Selection -->
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/> <!-- Auto-Start Toggle -->
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Row 1: Display Name -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Display Name" Foreground="#9CA3AF" FontSize="11.5" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InspectorDisplayNameText" Grid.Row="0" Grid.Column="1" Text="Loading..." Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>

                                    <!-- Row 2: Created Date -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Created" Foreground="#9CA3AF" FontSize="11.5" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InspectorCreatedText" Grid.Row="2" Grid.Column="1" Text="Loading..." Foreground="White" FontSize="11.5" VerticalAlignment="Center"/>

                                    <!-- Row 3: Session Health -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Session" Foreground="#9CA3AF" FontSize="11.5" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="InspectorStatusText" Grid.Row="4" Grid.Column="1" Text="Checking..." Foreground="#10B981" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>

                                    <!-- Row 4: Tag Selection -->
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Account Tag" Foreground="#9CA3AF" FontSize="11.5" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="InspectorTagComboBox" 
                                              Grid.Row="6" 
                                              Grid.Column="1" 
                                              Height="26" 
                                              Background="#111112" 
                                              Foreground="White" 
                                              BorderBrush="#1C1C1E" 
                                              VerticalContentAlignment="Center"
                                              SelectionChanged="InspectorTagComboBox_SelectionChanged">
                                        <ComboBoxItem Content="None"/>
                                        <ComboBoxItem Content="Main"/>
                                        <ComboBoxItem Content="Alt"/>
                                        <ComboBoxItem Content="Bot"/>
                                        <ComboBoxItem Content="Dev"/>
                                    </ComboBox>

                                    <!-- Row 5: Auto-Start Toggle -->
                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Auto-Launch" Foreground="#9CA3AF" FontSize="11.5" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="InspectorAutoStartCheck" 
                                              Grid.Row="8" 
                                              Grid.Column="1" 
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Checked="InspectorAutoStartCheck_Changed"
                                              Unchecked="InspectorAutoStartCheck_Changed"/>

                                    <!-- Row 6: Action Buttons + Notes -->
                                    <Grid Grid.Row="10" Grid.ColumnSpan="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="6"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Row="0" Grid.Column="0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="COPY COOKIE"
                                                Height="28"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Click="CopyCookieButton_Click"/>

                                        <Button Grid.Row="0" Grid.Column="2"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="OPEN PROFILE"
                                                Height="28"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Click="OpenProfileButton_Click"/>

                                        <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Text="Notes" Foreground="#9CA3AF" FontSize="11.5"/>
                                        <TextBox x:Name="InspectorNotesBox" Grid.Row="4" Grid.ColumnSpan="3"
                                                 Height="56" Background="#111112" Foreground="White" BorderBrush="#1C1C1E"
                                                 FontSize="11" Padding="6,4"
                                                 TextWrapping="Wrap" AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 ToolTip="Private notes for this account (saved automatically)"
                                                 TextChanged="InspectorNotesBox_TextChanged"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <!-- ================= SETTINGS OVERLAY MENU ================= -->
            <Grid x:Name="SettingsOverlay" Grid.RowSpan="2" Grid.ColumnSpan="5" Background="#E60A0A0B" Visibility="Collapsed" Panel.ZIndex="100" WindowChrome.IsHitTestVisibleInChrome="True">
                <Border Width="380" MaxHeight="500" Style="{StaticResource GlassCardStyle}" Padding="20,16" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Row 0: Title -->
                            <RowDefinition Height="*"/>    <!-- Row 1: Scrollable Content -->
                            <RowDefinition Height="Auto"/> <!-- Row 2: Save & Close Button -->
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Application Settings" Foreground="White" FontSize="14.5" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource CircleButtonStyle}" HorizontalAlignment="Right" Click="CloseSettingsOverlay_Click">
                                <Path Data="{StaticResource CloseGeometry}" Fill="#B2FFFFFF" Width="10" Height="10" Stretch="Uniform"/>
                            </Button>
                        </Grid>

                        <!-- Scrollable Options Content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,6,0">
                                <Border Height="1" Background="#1C1C1E" Margin="0,0,0,12"/>

                                <!-- Toggle 1: Obfuscation -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Encrypt Accounts File (DPAPI)" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Encrypts Roblox session cookies in accounts.json using Windows DPAPI to prevent local theft." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ObfuscateToggle" 
                                              Grid.Column="1" 
                                              Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center"
                                              Checked="SettingToggle_Changed"
                                              Unchecked="SettingToggle_Changed"/>
                                </Grid>

                                <!-- Toggle 2: Silent Clean logs -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Auto-Clean Logs on Launch" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Clears tracking logs and client temporary files automatically on boot." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="AutoCleanLogsToggle" 
                                              Grid.Column="1" 
                                              Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center"
                                              Checked="SettingToggle_Changed"
                                              Unchecked="SettingToggle_Changed"/>
                                </Grid>

                                <!-- Slider: FPS Limit -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Target Roblox FPS Limit" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Adjust client frame rates (30 FPS to Unlimited)." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="FpsValueLabel" Grid.Column="1" Text="Unlimited" Foreground="#10B981" FontSize="12.5" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Slider x:Name="FpsSlider" 
                                            Grid.Row="2" 
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" 
                                            Maximum="370" 
                                            Value="370" 
                                            IsSnapToTickEnabled="True" 
                                            TickFrequency="10"
                                            Cursor="Hand"
                                            ValueChanged="FpsSlider_ValueChanged"/>
                                </Grid>

                                <!-- Toggle 3: Sort Alphabetically -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Sort Accounts Alphabetically" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Sorts the accounts list alphabetically by username (A-Z)." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="SortAlphabeticallyToggle" 
                                              Grid.Column="1" 
                                              Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center"
                                              Checked="SettingToggle_Changed"
                                              Unchecked="SettingToggle_Changed"/>
                                </Grid>

                                <Border Height="1" Background="#1C1C1E" Margin="0,2,0,12"/>

                                <!-- Custom Launch Arguments -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Launch Arguments" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Command line switches (e.g. --fullscreen)." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="CustomLaunchArgsInput" 
                                             Grid.Column="1" 
                                             Style="{StaticResource GlowingTextBoxStyle}" 
                                             Height="28" 
                                             FontSize="11.5"
                                             Padding="6,2"
                                             TextChanged="SettingsInput_Changed"/>
                                </Grid>

                                <!-- Toggle: Disable Telemetry -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Disable Telemetry FFlags" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Blocks tracking and analytics sending to Roblox." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="DisableTelemetryToggle" 
                                              Grid.Column="1" 
                                              Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center"
                                              Checked="SettingToggle_Changed"
                                              Unchecked="SettingToggle_Changed"/>
                                </Grid>

                                <!-- Toggle: Optimize Graphics -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Optimize Graphics FFlags" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Forces minimum shaders and Level 1 graphics for performance." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="OptimizeGraphicsToggle" 
                                              Grid.Column="1" 
                                              Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center"
                                              Checked="SettingToggle_Changed"
                                              Unchecked="SettingToggle_Changed"/>
                                </Grid>

                                <Border Height="1" Background="#1C1C1E" Margin="0,2,0,12"/>

                                <!-- Discord Rich Presence -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Discord Rich Presence" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Shows the active account and session time on your Discord profile." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="DiscordRpcToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Checked="SettingToggle_Changed"
                                              Unchecked="SettingToggle_Changed"/>
                                </Grid>

                                <!-- Discord RPC Customization Fields (Visible only when RPC is toggled on) -->
                                <StackPanel Margin="0,0,0,14">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=DiscordRpcToggle}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Custom Discord App ID -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Discord App ID" Foreground="#9CA3AF" FontSize="11.5" VerticalAlignment="Center"/>
                                        <TextBox x:Name="DiscordAppIdInput" 
                                                 Grid.Column="1" 
                                                 Style="{StaticResource GlowingTextBoxStyle}" 
                                                 Height="26" 
                                                 FontSize="11"
                                                 Padding="6,2"
                                                 FontFamily="Consolas"
                                                 TextChanged="DiscordRpcSetting_Changed"/>
                                    </Grid>

                                    <Border Height="1" Background="#1C1C1E" Margin="0,0,0,12"/>

                                    <!-- Custom Activity Details (Playing as...) -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Status Text" Foreground="#9CA3AF" FontSize="11.5" VerticalAlignment="Center"/>
                                        <TextBox x:Name="DiscordDetailsInput" 
                                                 Grid.Column="1" 
                                                 Style="{StaticResource GlowingTextBoxStyle}" 
                                                 Height="26" 
                                                 FontSize="11"
                                                 Padding="6,2"
                                                 TextChanged="DiscordRpcSetting_Changed"/>
                                    </Grid>

                                    <!-- Custom Activity State (Place ID / Game Name) -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Sub-Status Text" Foreground="#9CA3AF" FontSize="11.5" VerticalAlignment="Center"/>
                                        <TextBox x:Name="DiscordStateInput" 
                                                 Grid.Column="1" 
                                                 Style="{StaticResource GlowingTextBoxStyle}" 
                                                 Height="26" 
                                                 FontSize="11"
                                                 Padding="6,2"
                                                 TextChanged="DiscordRpcSetting_Changed"/>
                                    </Grid>
                                    
                                    <Border Height="1" Background="#1C1C1E" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- App Lock (PIN) -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="App Lock (PIN)" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="PinLockStatusText" Text="Require a PIN each time the manager launches." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            x:Name="SetPinButton"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="SET PIN"
                                            Height="28"
                                            Width="90"
                                            FontSize="9.5"
                                            FontWeight="Bold"
                                            VerticalAlignment="Center"
                                            Click="SetPin_Click"/>
                                </Grid>

                                <!-- Theme Accent Selection -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Theme Accent" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Choose a primary color scheme for the application." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ComboBox x:Name="ThemeAccentComboBox" 
                                              Grid.Column="1"
                                              Width="150" Height="28"
                                              VerticalAlignment="Center"
                                              SelectionChanged="ThemeAccentComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Emerald"/>
                                        <ComboBoxItem Content="Violet"/>
                                        <ComboBoxItem Content="Crimson"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Storage & Log Manager -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Roblox Logs &amp; Cache" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="LogSizeStatusText" Text="Roblox log files size: Checking..." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button x:Name="OpenLogFolderButton"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="📂"
                                                Height="28" Width="32"
                                                ToolTip="Open Roblox Logs Folder"
                                                Margin="0,0,6,0"
                                                FontWeight="Bold"
                                                Click="OpenLogFolderButton_Click"/>
                                        <Button x:Name="CleanLogsNowButton"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="CLEAN NOW"
                                                Height="28" Width="90"
                                                FontSize="9.5"
                                                FontWeight="Bold"
                                                Click="CleanLogsNowButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Backup / Restore / Verify -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="BACKUP PROFILES"
                                            Height="30" FontSize="9.5" FontWeight="Bold"
                                            Click="BackupProfiles_Click"/>
                                    <Button Grid.Row="0" Grid.Column="2"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="RESTORE PROFILES"
                                            Height="30" FontSize="9.5" FontWeight="Bold"
                                            Click="RestoreProfiles_Click"/>
                                    <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="VERIFY ALL COOKIES"
                                            Height="30" FontSize="9.5" FontWeight="Bold"
                                            Click="VerifyAllCookies_Click"/>
                                </Grid>

                                <!-- Metadata Info Footer -->
                                <Grid>
                                    <Border Height="1" Background="#1C1C1E" VerticalAlignment="Top"/>
                                    <StackPanel Margin="0,10,0,0">
                                        <Grid>
                                            <TextBlock Text="Roblox Installation Info" Foreground="White" FontSize="11.5" FontWeight="Bold"/>
                                            <TextBlock x:Name="RobloxVersionInfoText" Text="Roblox Version: Unknown" Foreground="#10B981" FontSize="11" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="RobloxVersionDescText" Grid.Column="0" Text="Detected local player versions under LocalAppData\Roblox." Foreground="#616163" FontSize="10" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,10,0"/>
                                            <Button Grid.Column="1" 
                                                    Content="EXPLORE" 
                                                    Style="{StaticResource SecondaryButtonStyle}" 
                                                    Height="24" 
                                                    Width="75"
                                                    FontSize="9.5" 
                                                    FontWeight="Bold" 
                                                    Click="ExploreRobloxFolder_Click" 
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Close Button -->
                        <Button Grid.Row="2" 
                                Style="{StaticResource PrimaryButtonStyle}" 
                                Content="SAVE &amp; CLOSE" 
                                Height="36" 
                                Click="CloseSettingsOverlay_Click"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ================= GROUPS MANAGEMENT OVERLAY ================= -->
            <Grid x:Name="GroupsOverlay" Grid.RowSpan="2" Grid.ColumnSpan="5" Background="#E60A0A0B" Visibility="Collapsed" Panel.ZIndex="101" WindowChrome.IsHitTestVisibleInChrome="True">
                <Border Style="{StaticResource GlassCardStyle}" Width="400" MaxHeight="550" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Title & Close -->
                            <RowDefinition Height="Auto"/> <!-- Dropdown / New Group Button -->
                            <RowDefinition Height="*"/>    <!-- Group Config Form -->
                            <RowDefinition Height="Auto"/> <!-- Actions (Save/Delete) -->
                        </Grid.RowDefinitions>

                        <!-- Title & Close -->
                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <TextBlock Text="Manage Launch Groups" Foreground="White" FontSize="14.5" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource CircleButtonStyle}" HorizontalAlignment="Right" Click="CloseGroupsOverlay_Click">
                                <Path Data="{StaticResource CloseGeometry}" Fill="#B2FFFFFF" Width="10" Height="10" Stretch="Uniform"/>
                            </Button>
                        </Grid>

                        <!-- Group Selector & Creation Row -->
                        <Grid Grid.Row="1" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="OverlayGroupSelector" 
                                      Height="36" 
                                      Background="#111112" 
                                      Foreground="#E5E7EB" 
                                      BorderBrush="#1C1C1E" 
                                      Padding="8,0,0,0"
                                      VerticalContentAlignment="Center"
                                      SelectionChanged="OverlayGroupSelector_SelectionChanged"/>
                            <Button Grid.Column="1" 
                                    Style="{StaticResource PrimaryButtonStyle}" 
                                    Content="➕ NEW" 
                                    Width="70" Height="36" 
                                    Margin="8,0,0,0"
                                    Click="NewGroupButton_Click"/>
                        </Grid>

                        <!-- Group Config Form (Scrollable) -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,14">
                            <StackPanel x:Name="GroupFormPanel" Visibility="Collapsed">
                                <!-- Name Input -->
                                <TextBlock Text="Group Name" Foreground="White" FontSize="11.5" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBox x:Name="GroupNameTextBox" Style="{StaticResource GlowingTextBoxStyle}" Height="36" Margin="0,0,0,12" Foreground="White"/>

                                <!-- Place ID Input -->
                                <TextBlock Text="Target Place ID (Optional override)" Foreground="White" FontSize="11.5" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBox x:Name="GroupPlaceIdTextBox" Style="{StaticResource GlowingTextBoxStyle}" Height="36" Margin="0,0,0,12" Foreground="White" FontFamily="Consolas"/>

                                <!-- VIP Link Input -->
                                <TextBlock Text="Private Server Link/Code (Optional override)" Foreground="White" FontSize="11.5" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBox x:Name="GroupVipTextBox" Style="{StaticResource GlowingTextBoxStyle}" Height="36" Margin="0,0,0,12" Foreground="White"/>

                                <!-- Accounts List with Checkboxes -->
                                <TextBlock Text="Select Accounts in Group" Foreground="White" FontSize="11.5" FontWeight="Bold" Margin="0,0,0,6"/>
                                <Border BorderBrush="#1C1C1E" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                                    <ListBox x:Name="GroupAccountsListBox" Height="150" Background="#111112" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Username}" 
                                                          Foreground="White" 
                                                          Margin="4,4"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Actions -->
                        <Grid Grid.Row="3">
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="🗑️ DELETE" HorizontalAlignment="Left" Width="100" Height="36" Click="DeleteGroupButton_Click"/>
                            <Button Style="{StaticResource PrimaryButtonStyle}" Content="💾 SAVE GROUP" HorizontalAlignment="Right" Width="130" Height="36" Click="SaveGroupButton_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            <!-- ================= FLOATING TOAST NOTIFICATION ================= -->
            <Border x:Name="ToastNotification"
                    Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,24,24"
                    Padding="16,10"
                    Background="#FA0E0E10"
                    BorderThickness="1"
                    BorderBrush="#1C1C1E"
                    CornerRadius="8"
                    MaxWidth="320"
                    Visibility="Collapsed"
                    RenderTransformOrigin="0.5,0.5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Color="Black" Opacity="0.4" ShadowDepth="2"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToastTranslate" Y="20"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Pulsating indicator dot -->
                    <Ellipse x:Name="ToastIndicatorDot" Grid.Column="0" Width="8" Height="8" Fill="#10B981" Margin="0,0,10,0" VerticalAlignment="Center"/>

                    <TextBlock x:Name="ToastMessageText" 
                               Grid.Column="1" 
                               Text="Notification Message" 
                               Foreground="White" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
